*.png       binary
*.jpg       binary
*.jpeg      binary
*.bmp       binary
*.tga       binary
*.wav       binary
*.ogg       binary
*.flac      binary
*.ttf       binary
*.otf       binary

# Save files
*.txt       text eol=lf

# Không track file build
build/      export-ignore
build_win/  export-ignore
