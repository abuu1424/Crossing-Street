* text=auto

*.cpp       text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.c         text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.json      text eol=lf

# CMake
CMakeLists.txt  text eol=lf
